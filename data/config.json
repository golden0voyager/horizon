{
  "version": "1.0",
  "ai": {
    // AI 提供商: openai, ali, anthropic, gemini, azure, doubao, minimax, deepseek, modelscope, xiaomimimo, moonshotai, openrouter, groq, siliconflow, nvidia
    // 系统已内置各平台的官方 Base URL。如果使用自定义地址，请在 base_url 中手动指定。
    "provider": "sensenova",
    // 多供应商 Fallback 链：当主供应商失败时自动降级到下一个
    // 支持环境变量 HORIZON_AI_PROVIDER=sensenova,openrouter,gemini
    "provider_chain": "sensenova,openrouter,gemini",
    // 模型名称：请根据所选提供商填写对应的模型 ID（如 qwen-max, deepseek-chat, moonshot-v1-8k 等）
    "model": "DeepSeek-V3-1",
    "base_url": "",
    // 如果你需要使用特殊代理，系统会优先读取 .env 中的 {PROVIDER}_BASE_URL（如 DEEPSEEK_BASE_URL）。你也可以用 base_url_env 强制指定其他变量名。
    "base_url_env": "",
    // 环境变量：请在 .env 中设置对应的 API Key，并在此处填入变量名（如 DEEPSEEK_API_KEY）
    "api_key_env": "SENSENOVA_API_KEY",
    "temperature": 0.3,
    // 适当减小 max_tokens (这是生成长度限制) 以提高稳定性
    "max_tokens": 8192,
    // 摘要生成的语言 (改为 ["zh"] 仅生成中文以节省 token)
    "languages": [
      "zh"
    ]
  },
  "sources": {
    "github": [
      {
        // 监控 OpenAI 官方动态
        "type": "user_events",
        "username": "openai",
        "enabled": true
      },
      {
        // 监控 Anthropic 官方动态
        "type": "user_events",
        "username": "anthropic-ai",
        "enabled": true
      },
      {
        // 监控 DeepSeek 官方动态
        "type": "user_events",
        "username": "deepseek-ai",
        "enabled": true
      },
      {
        // 监控月之暗面 (Moonshot AI) 官方动态
        "type": "user_events",
        "username": "MoonshotAI",
        "enabled": true
      },
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 150
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "artificial",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "OpenAI",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 30
        },
        {
          "subreddit": "ClaudeAI",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 20
        }
      ],
      "fetch_comments": 10,
      "client_id_env": "REDDIT_CLIENT_ID",
      "client_secret_env": "REDDIT_CLIENT_SECRET",
      "user_agent": "Horizon-Aggregator/1.0"
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20
        }
      ]
    },
    "twitter": {
      "enabled": true,
      "users": [
        "karpathy",
        "sama",
        "ylecun",
        "demishassabis",
        "DarioAmodei",
        "drfeifei",
        "ilyasut",
        "AndrewYNg",
        "DrJimFan",
        "lilianweng",
        "jasonwei",
        "fchollet",
        "OpenAI",
        "AnthropicAI",
        "GoogleDeepMind",
        "xAI",
        "deepseek_ai",
        "nvidia",
        "huggingface",
        "cursor_ai",
        "dotey",
        "op7418",
        "rowancheung",
        "techreview",
        "theinformation"
      ],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5,
      "cookie_dir": "data",
      "cookie_file_pattern": "x_cookies_*.json"
    }
  },
  "filtering": {
    "ai_score_threshold": 8.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}